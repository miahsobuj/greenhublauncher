<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/equalizer"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <!-- Presets -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/preset"
        android:textSize="14sp"
        android:textColor="@color/text_secondary" />

    <Spinner
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/primary_green" />

    <!-- Bass Boost -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/bass_boost"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <Switch
            android:id="@+id/switch_bass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_bass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:value="50"
        android:valueFrom="0"
        android:valueTo="100"
        app:thumbColor="@color/accent_green"
        app:trackColorActive="@color/primary_green"
        app:trackColorInactive="@color/text_disabled" />

    <!-- Virtualizer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/virtualizer"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <Switch
            android:id="@+id/switch_virtual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_virtual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:value="30"
        android:valueFrom="0"
        android:valueTo="100"
        app:thumbColor="@color/accent_green"
        app:trackColorActive="@color/primary_green"
        app:trackColorInactive="@color/text_disabled" />

</LinearLayout>