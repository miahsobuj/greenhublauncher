<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- Base GreenHub style -->
    <style name="GreenHub">
    </style>
    
    <!-- Base Theme -->
    <style name="Theme.GreenHub" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/emerald_green</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorSurfaceVariant">@color/dark_card</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/semi_dark</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Ripple Effect -->
        <item name="colorControlHighlight">@color/glass_green</item>
        
        <!-- Overlays -->
        <item name="android:windowTranslucentStatus">true</item>
    </style>
    
    <!-- Theme with ActionBar -->
    <style name="Theme.GreenHub.WithActionBar" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/surface_dark</item>
    </style>
    
    <!-- No ActionBar Variant -->
    <style name="Theme.GreenHub.NoActionBar" parent="Theme.GreenHub">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- Full Screen Variant -->
    <style name="Theme.GreenHub.Fullscreen" parent="Theme.GreenHub.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <!-- Splash Screen -->
    <style name="Theme.GreenHub.Splash" parent="Theme.GreenHub.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
    
    <!-- Card Styles -->
    <style name="GreenHub.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <style name="GreenHub.Card.Flat">
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/dark_bg_elevated</item>
    </style>
    
    <!-- Button Styles -->
    <style name="GreenHub.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primary_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="GreenHub.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_green</item>
        <item name="android:textColor">@color/accent_green</item>
    </style>
    
    <!-- Text Styles -->
    <style name="GreenHub.Text">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="GreenHub.Text.Title" parent="GreenHub.Text">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="GreenHub.Text.Headline" parent="GreenHub.Text">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="GreenHub.Text.Body" parent="GreenHub.Text">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Widget Styles -->
    <style name="GreenHub.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="trackTint">@color/primary_green</item>
    </style>
    
    <style name="GreenHub.Slider" parent="Widget.Material3.Slider">
        <item name="trackColorActive">@color/primary_green</item>
        <item name="thumbColor">@color/accent_green</item>
    </style>
    
</resources>