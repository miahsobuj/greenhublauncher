<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Launcher Permissions -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.INSTALL_SHORTCUT" />
    <uses-permission android:name="android.permission.UNINSTALL_SHORTCUT" />
    
    <!-- File Manager Permissions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    
    <!-- Call & Contacts Permissions -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    
    <!-- Browser Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Video Downloader -->
    <uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    
    <!-- Audio Record for Equalizer Visualizer -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_green"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_green_circle"
        android:supportsRtl="true"
        android:theme="@style/Theme.GreenHub"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="34">

        <!-- Launcher Intent Filter -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- File Manager -->
        <activity
            android:name=".FileManagerActivity"
            android:label="@string/file_manager"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Calculator -->
        <activity
            android:name=".CalculatorActivity"
            android:label="@string/calculator"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Browser -->
        <activity
            android:name=".BrowserActivity"
            android:label="@string/browser"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Notepad -->
        <activity
            android:name=".NotepadActivity"
            android:label="@string/notepad"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Video Downloader -->
        <activity
            android:name=".VideoDownloaderActivity"
            android:label="@string/video_downloader"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Music Player -->
        <activity
            android:name=".MusicPlayerActivity"
            android:label="@string/music_player"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Phone -->
        <activity
            android:name=".PhoneActivity"
            android:label="@string/phone"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Contacts -->
        <activity
            android:name=".ContactsActivity"
            android:label="@string/contacts"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Settings -->
        <activity
            android:name=".SettingsActivity"
            android:label="@string/settings"
            android:theme="@style/Theme.GreenHub.NoActionBar"
            android:exported="false" />

        <!-- Music Player Service -->
        <service
            android:name=".MusicService"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>